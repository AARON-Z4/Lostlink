# ============================================================
# LostLink Frontend — Environment Variables
# Copy to .env and fill in values.
# ============================================================

# Backend Express API — NO trailing slash, NO /api prefix
# Backend runs on port 5000 by default (see backend/.env)
VITE_API_URL=http://localhost:5000

# true  → uses in-memory mock data (no backend needed)
# false → calls real Express backend on VITE_API_URL
VITE_USE_MOCK=true
